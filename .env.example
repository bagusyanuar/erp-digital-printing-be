APP_NAME=erp-digital-printing
APP_VERSION="1.0.0"

APP_ENV=development
APP_PORT=8000
APP_DEBUG=false
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=db_erp_printing
DB_SSLMODE=disable

JWT_ISSUER=erp-digital-printing-app
JWT_SECRET=jwt-secret
JWT_EXPIRATION=5 #minute
JWT_SECRET_REFRESH=jwt-secret-refresh
JWT_EXPIRATION_REFRESH=30 #day

LOG_FILE=.logs/app.log
LOG_MAX_SIZE=10
LOG_MAX_BACKUPS=3
LOG_MAX_AGE=7
LOG_COMPRESS=true
LOG_LEVEL=debug

CASBIN_MODEL_PATH=configs/rbac_model.conf
